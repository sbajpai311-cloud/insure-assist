# InsureMO — Life Term (LimoPOC tenant)
INSUREMO_AUTH_URL=https://portal.insuremo.com/cas/ebao/v1/json/tickets
INSUREMO_API_BASE=https://portal-gw.insuremo.com/ebaoli/1.0
INSUREMO_USERNAME=limopocuser1
INSUREMO_PASSWORD=Poc@9876
INSUREMO_TENANT_NAME=LimoPOC
INSUREMO_TENANT_ID=f63cdb8d-240d-4e26-b0d9-05e9276a65ca

# Health & Wellness Bundle — InsureMO tenant: inecosystem
INSUREMO_HALB_TENANT=inecosystem
INSUREMO_HALB_BASE=https://inecosystem-gimc.insuremo.com
INSUREMO_HALB_API_BASE=https://inecosystem-gimc.insuremo.com/proposal/v1
INSUREMO_HALB_ADMIN_UI=https://inecosystem-gimc.insuremo.com/ui/admin/#/

# Agent Auth — simple credential login (no Azure AD required)
# Override with JSON array in production:
# [{"agentId":"a1","name":"My Agent","email":"a@b.com","password":"Secret@123","tenantIds":["LimoPOC"]}]
AGENT_CREDENTIALS=

# HALB tenant credentials (optional — leave blank to use mock token in dev)
INSUREMO_HALB_USERNAME=
INSUREMO_HALB_PASSWORD=
INSUREMO_HALB_AUTH_URL=https://inecosystem-gimc.insuremo.com/cas/ebao/v1/json/tickets

# --- Azure AD (future use when available) ---
# AZURE_AD_TENANT_ID=<your-azure-ad-tenant-id>
# AZURE_AD_CLIENT_ID=<your-app-registration-client-id>
# AZURE_AD_CLIENT_SECRET=<your-app-registration-client-secret>

# Payment Gateway
# Options: mock (default, no credentials needed) | razorpay | payu
PAYMENT_GATEWAY=mock
# Test card numbers for mock (deterministic outcomes):
# SUCCESS:            4111 1111 1111 1111
# SUCCESS (MC):       5500 0000 0000 0004
# DECLINED:           4000 0000 0000 0002
# INSUFFICIENT FUNDS: 4000 0000 0000 9995
# PENDING (3DS):      4000 0000 0000 3220
# FRAUD BLOCKED:      4100 0000 0000 0001
# Expiry: any future (12/29) | CVV: any 3 digits (123)

# (Swap to live when ready)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# App
JWT_SECRET=<generate_strong_secret>
PORT=3000
NODE_ENV=production
